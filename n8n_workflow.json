{
  "name": "SideHustle Launchpad - Pipeline",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "sidehustle-trigger",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "1a2b3c4d-5e6f-7a8b-9c0d-1e2f3a4b5c6d",
      "name": "Webhook Node (From Botpress)",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "param-1",
              "name": "studentName",
              "value": "={{ $json.body.student_name }}",
              "type": "string"
            },
            {
              "id": "param-2",
              "name": "hustleSkill",
              "value": "={{ $json.body.core_skill }}",
              "type": "string"
            },
            {
              "id": "param-3",
              "name": "targetEmail",
              "value": "={{ $json.body.email_address }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "2b3c4d5e-6f7a-8b9c-0d1e-2f3a4b5c6d7e",
      "name": "Map Input Fields",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3,
      "position": [470, 300]
    },
    {
      "parameters": {
        "model": "google/gemini-1.5-flash",
        "prompt": "=Generate a comprehensive micro-business blueprint for {{ $json.studentName }} who wants to monetize their skill in {{ $json.hustleSkill }}.",
        "options": {}
      },
      "id": "3c4d5e6f-7a8b-9c0d-1e2f-3a4b5c6d7e8f",
      "name": "Google AI Studio Node",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [690, 300]
    },
    {
      "parameters": {
        "sendTo": "={{ $('Map Input Fields').item.json.targetEmail }}",
        "subject": "Your Custom SideHustle Launchpad Blueprint!",
        "messageType": "html",
        "html": "=<h3>Hi {{ $('Map Input Fields').item.json.studentName }},</h3><p>Your business blueprint is ready! Here are your execution steps:</p><div>{{ $json.text }}</div>",
        "options": {}
      },
      "id": "4d5e6f7a-8b9c-0d1e-2f3a-4b5c6d7e8f9a",
      "name": "Gmail / Email Delivery Node",
      "type": "n8n-nodes-base.email",
      "typeVersion": 1,
      "position": [910, 300]
    }
  ],
  "connections": {
    "Webhook Node (From Botpress)": {
      "main": [
        [
          {
            "node": "Map Input Fields",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Map Input Fields": {
      "main": [
        [
          {
            "node": "Google AI Studio Node",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Google AI Studio Node": {
      "main": [
        [
          {
            "node": "Gmail / Email Delivery Node",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {},
  "staticData": {},
  "meta": {}
}
